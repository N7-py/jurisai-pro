# JurisAI Pro Environment Variables

# OpenAI API Key (Required for GPT-4o)
OPENAI_API_KEY=sk-your-openai-key-here

# HuggingFace API Token (Required for open source models)
HF_API_TOKEN=hf_your-huggingface-token-here

# JWT Secret for authentication
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# SMTP Settings (Optional - for email verification)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password-here

# Port (Optional - defaults to 3000)
PORT=3000